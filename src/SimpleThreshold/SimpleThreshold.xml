<?xml version="1.0" encoding="UTF-8"?>
<executable>
    <category>MIATT.HW04.sramtilak</category>
    <title>SimpleThreshold_sramtilak</title>
    <description>Simple Threshold Filter</description>
    <version>1.0</version>
    <documentation-url>https://github.com/uiowaMIATT2026/hw04-Swati-Ramtilak.git/main/src/SimpleThreshold</documentation-url>
    <license>Apache 2.0</license>
    <contributor>Swati Ramtilak</contributor>

    <parameters>
        <label>Input-Output</label>
        <description>Input and output volume parameters</description>

        <image>
            <name>inputVolume</name>
            <longflag>inputVolume</longflag>
            <label>Input-Volume</label>
            <channel>input</channel>
            <description>3D NIFTI image</description>
        </image>

        <image>
            <name>outputVolume</name>
            <longflag>outputVolume</longflag>
            <label>Output-Volume</label>
            <channel>output</channel>
            <description>3D NIFTI image</description>
        </image>

    </parameters>

    <parameters>
        <label>Thresholding-Parameters</label>
        <description>Thresholding parameters</description>

        <double>
            <name>lowThreshold</name>
            <longflag>lowThreshold</longflag>
            <label>Low-Threshold</label>
            <description>The lower threshold value</description>
        </double>

        <double>
            <name>highThreshold</name>
            <longflag>highThreshold</longflag>
            <label>High-Threshold</label>
            <description>The upper threshold value</description>
        </double>

        <double>
            <name>outsideValue</name>
            <longflag>outsideValue</longflag>
            <label>Outside-Value</label>
            <description>Value for pixels outside threshold range</description>
        </double>

        <double>
            <name>insideValue</name>
            <longflag>insideValue</longflag>
            <label>Inside-Value</label>
            <description>Value for pixels inside threshold range</description>
        </double>

    </parameters>
</executable>